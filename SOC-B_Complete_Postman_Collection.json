            "body": {
              "mode": "raw",
              "raw": "{\n  \"url\": \"https://cdn.example.com/stories/test_{{$timestamp}}.mp4\",\n  \"b2_object_key\": \"stories/test_{{$timestamp}}.mp4\",\n  \"file_size\": 1234567,\n  \"content_type\": \"video/mp4\",\n  \"story_type\": \"emotion\",\n  \"emotion_preset\": \"joyful\",\n  \"challenge_type\": null,\n  \"recipe_ids\": []\n}"
            },
            "url": {
              "raw": "{{base_url}}/stories/confirm",
              "host": ["{{base_url}}"],
              "path": ["stories", "confirm"]
            },
            "description": "Step 2: Confirm story upload with metadata. Triggers Celery validation."
          },
          "response": []
        },
        {
          "name": "1.3 Confirm Story - Challenge Type",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
