      "name": "1. Story Upload Flow",
      "description": "Complete 3-step story upload process",
      "item": [
        {
          "name": "1.1 Upload to Media Service",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": "",
                  "description": "Select video/image file"
                },
                {
                  "key": "type",
                  "value": "story",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{upload_url}}/api/upload",
              "host": ["{{upload_url}}"],
              "path": ["api", "upload"]
            },
            "description": "Step 1: Upload media to Tuan's upload service. Returns {url, key, size, mimetype}"
          },
          "response": []
        },
        {
          "name": "1.2 Confirm Story - Emotion Type",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.collectionVariables.set('story_id', res.story_id);",
                  "pm.test('Story created with pending status', function() {",
                  "    pm.expect(res.status).to.eql('pending');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-user-id",
                "value": "{{user_id}}"
              }
